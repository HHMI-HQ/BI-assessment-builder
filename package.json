{
  "name": "hhmi",
  "version": "0.0.0",
  "private": true,
  "description": "Question database and submission application for HHMI",
  "repository": {
    "type": "git",
    "url": "git@gitlab.coko.foundation:hhmi/hhmi.git"
  },
  "license": "MIT",
  "author": "Yannis Barlas",
  "main": "index.js",
  "scripts": {
    "clean": "sh clean.sh",
    "cz": "git cz",
    "storybook": "docker-compose -f docker-compose.storybook.yml up",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepare": "husky install"
  },
  "config": {
    "commitizen": {
      "path": "cz-customizable"
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@coko/lint": "^2.0.0"
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS && lint-staged"
    }
  }
}
