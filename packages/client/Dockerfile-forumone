# IMAGE FOR BUILDING
FROM node:16.19.0-bullseye-slim AS client-build
ENV NODE_ENV=production

RUN apt-get update \
    && apt-get upgrade -y \
    && apt-get install -y

WORKDIR /home/node/app

COPY package.json .
COPY yarn.lock .

RUN yarn install --frozen-lockfile --production

COPY . .

ARG SERVER_URL

ENV NODE_ENV='production'
ENV CLIENT_PAGE_TITLE='HHMI Assessment Builder'
ENV CLIENT_FAVICON_PATH='../static/favicon.ico'
ENV CLIENT_LANGUAGE='en-US'

ENV SERVER_URL=${SERVER_URL}

RUN yarn coko-client-build

FROM node:16.19.0-bullseye-slim AS client-serve

RUN apt-get update && apt-get install -y
RUN npm install --global serve

USER node

#COPY --from=0 /home/node/app/_build ./_build
RUN mkdir client
RUN cp -rf . client
