FROM node:20.19-bullseye-slim as server

RUN apt-get update \ 
    && apt-get upgrade -y \
    && apt-get install -y \
    git \
    make \
    g++ \
    python3

WORKDIR /home/node/hhmi

RUN chown -R node:node .
USER node

COPY package.json .
COPY yarn.lock .

RUN yarn install --frozen-lockfile
RUN yarn cache clean

COPY --chown=node:node . .

CMD ["yarn", "coko-server", "start"]
