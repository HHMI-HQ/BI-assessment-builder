FROM node:18.20.2-bullseye-slim as server

RUN apt-get update \ 
    && apt-get upgrade -y \
    && apt-get install -y \
    git \
    make \
    g++ \
    python3

WORKDIR /home/node/hhmi

# Copy the .platform directory to the app directory so it gets extracted
COPY ../../.platform /home/node/hhmi/.platform

COPY package.json .
COPY yarn.lock .

RUN chown -R node:node .
USER node

RUN yarn install --frozen-lockfile --production
RUN yarn cache clean

COPY --chown=node:node . .

CMD ["yarn", "coko-server", "start"]
