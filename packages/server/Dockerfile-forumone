FROM node:18.20.2-bullseye-slim as server-build

RUN apt-get update \
    && apt-get upgrade -y \
    && apt-get install -y \
    git \
    make \
    g++ \
    python3

WORKDIR /home/node/hhmi

COPY . .

#COPY package.json .
#COPY yarn.lock .

RUN chown -R node:node .
USER node

RUN yarn install --frozen-lockfile --production
COPY --chown=node:node . .

CMD ["yarn", "coko-server", "start"]
