FROM cokoapps/base:20 as server-build

RUN apt-get update \
    && apt-get upgrade -y \
    && apt-get install -y \
    git \
    make \
    g++ \
    python3

WORKDIR /home/node/hhmi

COPY .yarnrc.yml .
COPY package.json .
COPY yarn.lock .

RUN chown -R node:node .
USER node

RUN yarn install --immutable && yarn cache clean && rm -rf ~/.npm

COPY --chown=node:node . .

CMD ["yarn", "coko-server", "start"]
